PRODUCTION=1
APP_HOST=0.0.0.0
APP_PORT=8000
APP_AUTO_PORT=0

# Change both before production.
TEACHER_PASSWORD=change-this-teacher-password
ADMIN_TOKEN=change-this-admin-token

# Comma-separated browser origins allowed to call the API in production.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

DB_NAME=school.db
FACE_DIR=face_database
SCREENSHOTS_DIR=screenshots
MAX_UPLOAD_BYTES=5242880

CAMERA_FPS=30
RECOGNITION_WIDTH=640
RECOGNITION_INTERVAL_SECONDS=0.18
